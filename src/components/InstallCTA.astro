---
import { type Locale } from '../i18n';

interface Props {
  locale: Locale;
  appStoreUrl?: string;
  playStoreUrl?: string;
}

const APP_STORE_JA = 'https://apps.apple.com/jp/app/%E3%82%B8%E3%83%A0%E3%83%AC%E3%82%B3ai-%E7%AD%8B%E3%83%88%E3%83%AC%E8%A8%98%E9%8C%B2-%E3%83%97%E3%83%AD%E3%82%B0%E3%83%A9%E3%83%A0%E4%BD%9C%E6%88%90/id6764790714';
const APP_STORE_EN = 'https://apps.apple.com/us/app/gymreco-ai/id6764790714';
const PLAY_STORE_JA = 'https://play.google.com/store/apps/details?id=com.gymreco.ai&hl=ja';
const PLAY_STORE_EN = 'https://play.google.com/store/apps/details?id=com.gymreco.ai&hl=en';
const { locale, appStoreUrl = locale === 'en' ? APP_STORE_EN : APP_STORE_JA, playStoreUrl = locale === 'en' ? PLAY_STORE_EN : PLAY_STORE_JA } = Astro.props;

const copy = locale === 'ja'
  ? {
      label: 'この計算、毎セッション手動でやる必要はない',
      desc: 'アプリなら1RM更新から重量の再計算・記録・グラフまで全部自動。今日のセットが終わったらそのまま入力するだけ。',
      google: 'Google Play で無料ダウンロード',
      apple: 'App Store で無料ダウンロード',
      badge: '無料 • iOS / Android',
    }
  : {
      label: 'Stop recalculating this every session',
      desc: 'The app auto-updates weights when your 1RM changes, logs every set, and charts your progress — all in one place. Just lift and tap.',
      google: 'Get it free on Google Play',
      apple: 'Download free on the App Store',
      badge: 'Free · iOS & Android',
    };
---

<div class="cta-box">
  <div class="cta-inner">
    <div class="cta-text">
      <p class="cta-badge">{copy.badge}</p>
      <h3>{copy.label}</h3>
      <p>{copy.desc}</p>
    </div>
    <div class="cta-buttons">
      <a href={playStoreUrl} class="store-btn" target="_blank" rel="noopener">
        <img src={`${import.meta.env.BASE_URL}badges/google-play.png`} alt={copy.google} />
      </a>
      {appStoreUrl !== '#' && (
        <a href={appStoreUrl} class="store-btn" target="_blank" rel="noopener">
          <img src={`${import.meta.env.BASE_URL}badges/app-store.svg`} alt={copy.apple} />
        </a>
      )}
    </div>
  </div>
</div>

<style>
.cta-box {
  background: linear-gradient(135deg, rgba(77,208,225,0.12) 0%, rgba(77,208,225,0.04) 100%);
  border: 1px solid rgba(77,208,225,0.3);
  border-radius: var(--radius-lg);
  padding: 32px;
  margin: 48px 0;
}
.cta-inner {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
.cta-text { flex: 1; min-width: 240px; }
.cta-badge {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: 8px;
}
.cta-text h3 { font-size: 20px; margin-bottom: 8px; color: var(--color-text); line-height: 1.4; }
.cta-text p  { color: var(--color-text-muted); font-size: 15px; line-height: 1.6; }
.cta-buttons { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
.store-btn img { display: block; height: 40px; width: auto; }
.store-btn { opacity: 0.9; transition: opacity 0.15s; }
.store-btn:hover { opacity: 1; }
</style>
