---
import '../styles/theme.css';
import { useTranslations, localePath, type Locale } from '../i18n';
import { programMeta } from '../lib/programs/index';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { locale, title, description, canonical, ogImage, jsonLd } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ?? t('site_title');
const pageDesc  = description ?? t('site_desc');
const siteUrl   = 'https://gymreco.app';
const canonicalUrl = canonical ?? Astro.url.href;
const altLocale: Locale = locale === 'ja' ? 'en' : 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathWithoutBase = Astro.url.pathname.slice(base.length) || '/';
const altPath = pathWithoutBase.replace(/^\/en/, '') || '/';
const altNavLink = altLocale === 'en' ? `${base}/en${altPath}` : `${base}${altPath}`;
const altUrl = altLocale === 'en' ? `${siteUrl}/en${altPath}` : `${siteUrl}${altPath}`;
const ogImg = ogImage ?? `${siteUrl}/og-default.png`;
const isJa = locale === 'ja';
const ogLocale = isJa ? 'ja_JP' : 'en_US';
const ogLocaleAlt = isJa ? 'en_US' : 'ja_JP';
---

<!DOCTYPE html>
<html lang={isJa ? 'ja' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang={isJa ? 'ja' : 'en'} href={canonicalUrl} />
  <link rel="alternate" hreflang={altLocale === 'ja' ? 'ja' : 'en'} href={altUrl} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${altPath}`} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={ogLocaleAlt} />
  <meta property="og:site_name" content="GymRec" />
  <meta name="theme-color" content="#4DD0E1" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />
  <meta name="twitter:image" content={ogImg} />

  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
  <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6316105968882227" crossorigin="anonymous"></script>
</head>
<body>

<header class="nav">
  <div class="container nav__inner">
    <a class="brand" href={localePath(locale, '/')} aria-label="GymRec">
      <img class="brand__mark" src={`${import.meta.env.BASE_URL}icon.png`} width="30" height="30" alt="GymRec" />
      <span class="brand__name">Gym<b>Rec</b></span>
    </a>
    <nav class="nav__links">
      <a href={localePath(locale, '/#programs')}>{isJa ? 'プログラム' : 'Programs'}</a>
      <a href={localePath(locale, '/#features')}>{isJa ? '特長' : 'Features'}</a>
      <a href={localePath(locale, '/#install')}>{isJa ? 'アプリ' : 'App'}</a>
    </nav>
    <div class="nav__right">
      <div class="lang-toggle" role="group" aria-label="Language">
        <a href={locale === 'ja' ? '#' : altNavLink} class={locale === 'ja' ? 'is-active' : ''}>JP</a>
        <a href={locale === 'en' ? '#' : altNavLink} class={locale === 'en' ? 'is-active' : ''}>EN</a>
      </div>
      <a class="btn btn--primary btn--sm nav__cta" href={localePath(locale, '/#install')}>
        {isJa ? 'アプリを入手' : 'Get the app'}
      </a>
      <button class="nav__burger" id="navBurger" aria-label={isJa ? 'メニューを開く' : 'Open menu'} aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="nav__mobile" id="navMobile">
  <a class="nav__mobile-link" href={localePath(locale, '/#programs')}>{isJa ? 'プログラム' : 'Programs'}</a>
  <a class="nav__mobile-link" href={localePath(locale, '/#features')}>{isJa ? '特長' : 'Features'}</a>
  <a class="nav__mobile-link" href={localePath(locale, '/#install')}>{isJa ? 'アプリ' : 'App'}</a>
  <a class="btn btn--primary btn--block nav__mobile-cta" href={localePath(locale, '/#install')}>
    {isJa ? 'アプリを入手' : 'Get the app'}
  </a>
</div>

<main>
  <slot />
</main>

<footer class="footer">
  <div class="container footer__inner">
    <div>
      <a class="brand" href={localePath(locale, '/')}>
        <img class="brand__mark" src={`${import.meta.env.BASE_URL}icon.png`} width="30" height="30" alt="GymRec" />
        <span class="brand__name">Gym<b>Rec</b></span>
      </a>
      <p class="footer__legal">© 2026 GymRec. {isJa ? 'プログラム計算ツール' : 'Program Calculator'}.</p>
    </div>
    <div class="footer__cols">
      <div class="footer__col">
        <h4>{isJa ? 'プログラム' : 'Programs'}</h4>
        {programMeta.map(p => (
          <a href={localePath(locale, `/programs/${p.slug}`)}>
            {isJa ? p.nameJa : p.nameEn}
          </a>
        ))}
      </div>
      <div class="footer__col">
        <h4>{isJa ? 'プロダクト' : 'Product'}</h4>
        <a href={localePath(locale, '/#features')}>{isJa ? '特長' : 'Features'}</a>
        <a href={localePath(locale, '/#install')}>{isJa ? 'アプリ' : 'App'}</a>
      </div>
    </div>
  </div>
</footer>

</body>
</html>

<style>
/* Nav */
.nav {
  position: sticky; top: 0; z-index: 50;
  background: color-mix(in oklab, var(--bg) 82%, transparent);
  backdrop-filter: saturate(140%) blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav__inner { height: 64px; display: flex; align-items: center; gap: 24px; }
.brand { display: flex; align-items: center; gap: 10px; font-weight: 700; letter-spacing: -0.01em; }
.brand__mark {
  width: 30px; height: 30px; border-radius: 8px;
  box-shadow: 0 0 0 1px rgba(77,208,225,.25), 0 6px 16px -6px rgba(77,208,225,.5);
  flex: none; object-fit: cover;
}
.brand__name { font-size: 16px; }
.brand__name b { color: var(--primary); }
.nav__links { display: flex; gap: 26px; margin-left: 8px; }
.nav__links a { color: var(--text-muted); font-size: 14px; transition: color .15s; }
.nav__links a:hover { color: var(--text); }
.nav__right { margin-left: auto; display: flex; align-items: center; gap: 14px; }

/* Lang toggle */
.lang-toggle {
  display: inline-flex; align-items: center;
  border: 1px solid var(--border); border-radius: 999px;
  padding: 3px; background: var(--surface);
  font-family: var(--font-mono);
}
.lang-toggle a {
  border: 0; background: transparent; color: var(--text-muted);
  font-size: 12px; font-weight: 600; letter-spacing: .06em;
  padding: 5px 12px; border-radius: 999px; transition: .15s;
  text-decoration: none;
}
.lang-toggle a.is-active { background: var(--surface-2); color: var(--text); box-shadow: inset 0 0 0 1px var(--border-2); }
.lang-toggle a:hover:not(.is-active) { color: var(--text); }

/* Hamburger */
.nav__burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  padding: 7px;
  background: transparent;
  border: none;
  cursor: pointer;
  flex: none;
}
.nav__burger span {
  display: block;
  width: 100%;
  height: 2px;
  background: var(--text-muted);
  border-radius: 1px;
  transition: transform .25s ease, opacity .2s ease;
}
.nav__burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav__burger.is-open span:nth-child(2) { opacity: 0; }
.nav__burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile menu */
.nav__mobile {
  display: none;
  position: fixed;
  top: 64px; left: 0; right: 0; bottom: 0;
  z-index: 49;
  background: var(--bg);
  border-top: 1px solid var(--border);
  padding: 8px var(--gutter, 24px) 32px;
  flex-direction: column;
  overflow-y: auto;
}
.nav__mobile.is-open { display: flex; }
.nav__mobile-link {
  display: block;
  font-size: 17px;
  font-weight: 600;
  padding: 18px 0;
  border-bottom: 1px solid var(--border);
  color: var(--text-muted);
  transition: color .15s;
}
.nav__mobile-link:first-child { border-top: 1px solid var(--border); margin-top: 8px; }
.nav__mobile-link:hover { color: var(--text); }
.nav__mobile-cta { margin-top: 24px; justify-content: center; }

@media (max-width: 820px) {
  .nav__links { display: none; }
  .nav__burger { display: flex; }
  .nav__cta { display: none; }
}
</style>

<script>
(function () {
  var burger = document.getElementById('navBurger');
  var menu = document.getElementById('navMobile');
  if (!burger || !menu) return;
  burger.addEventListener('click', function () {
    var open = menu.classList.toggle('is-open');
    burger.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
  menu.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', function () {
      menu.classList.remove('is-open');
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
})();
</script>
