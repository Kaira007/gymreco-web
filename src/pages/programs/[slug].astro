---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ProgramGenerator } from '../../components/ProgramGenerator';
import { programMeta } from '../../lib/programs/index';
import { useTranslations, localePath } from '../../i18n';
import '../../styles/generator.css';

export function getStaticPaths() {
  return programMeta.map(meta => ({ params: { slug: meta.slug }, props: { meta } }));
}

const { meta } = Astro.props;
const locale = 'ja';
const t = useTranslations(locale);

const levelBadge = meta.level === 'beginner' ? 'beginner' : meta.level === 'intermediate' ? 'intermediate' : 'advanced';
const levelLabel = meta.level === 'beginner' ? '初級' : meta.level === 'intermediate' ? '中級' : '上級';

const messages = {
  input_1rm:        t('input_1rm'),
  input_bench:      t('input_bench'),
  input_squat:      t('input_squat'),
  input_dead:       t('input_dead'),
  input_press:      t('input_press'),
  input_equipment:  t('input_equipment'),
  equip_barbell:    t('equip_barbell'),
  equip_dumbbell:   t('equip_dumbbell'),
  equip_machine:    t('equip_machine'),
  equip_cable:      t('equip_cable'),
  equip_chinning:   t('equip_chinning'),
  input_target:     t('input_target'),
  target_bench:     t('target_bench'),
  target_squat:     t('target_squat'),
  target_both:      t('target_both'),
  generate_btn:     t('generate_btn'),
  result_day:       t('result_day'),
  result_focus:     t('result_focus'),
  result_exercise:  t('result_exercise'),
  result_sets:      t('result_sets'),
  result_reps:      t('result_reps'),
  result_weight:    t('result_weight'),
  result_notes:     t('result_notes'),
  no_weight:        t('no_weight'),
  nutrition:        t('nutrition'),
  recovery:         t('recovery'),
  unit_label:       t('unit_label'),
  hint_1rm:         t('hint_1rm'),
  no_signup:        t('no_signup'),
  stat_top_weight:  t('stat_top_weight'),
  stat_total_sets:  t('stat_total_sets'),
  stat_week_volume: t('stat_week_volume'),
  stat_days:        t('stat_days'),
  bw_label:         t('bw_label'),
  equip_warning:    t('equip_warning'),
};

const siteUrl = 'https://gymreco.app';
const categoryLabel = meta.category === 'beginner' ? '初級' : meta.category === 'strength' ? 'ストレングス' : 'ハイパートロフィー';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'GymReco', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'プログラム', item: `${siteUrl}/#programs` },
    { '@type': 'ListItem', position: 3, name: categoryLabel, item: `${siteUrl}/#programs` },
    { '@type': 'ListItem', position: 4, name: meta.nameJa, item: `${siteUrl}/programs/${meta.slug}` },
  ],
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: `${meta.nameJa} 計算ツール`,
  description: meta.seoDescJa,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  url: `${siteUrl}/programs/${meta.slug}`,
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${meta.nameJa}計算ツールの使い方`,
  description: meta.descJa,
  totalTime: 'PT2M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: '1RMを入力する',
      text: '対象種目の1RM（最大挙上重量）をkg単位で入力欄に入力します。',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'プログラムを生成する',
      text: '「プログラムを生成」ボタンを押すと、全セッションの重量・セット・レップが自動で計算されます。',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'プランをジムに持っていく',
      text: '出力されたプランをそのままジムで実施するか、GymRecoアプリに取り込んでセットごとに記録できます。',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: meta.faq.map(item => ({
    '@type': 'Question',
    name: item.questionJa,
    acceptedAnswer: { '@type': 'Answer', text: item.answerJa },
  })),
};

const jsonLd = [softwareSchema, howToSchema, breadcrumbSchema, faqSchema];

const relatedPrograms = meta.relatedSlugs
  .map(s => programMeta.find(p => p.slug === s))
  .filter(Boolean);
---

<BaseLayout locale={locale} title={meta.seoTitleJa} description={meta.seoDescJa} jsonLd={jsonLd}>
  <div class="container">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={localePath(locale, '/')}>GymReco</a>
      <span class="sep">/</span>
      <a href={localePath(locale, '/#programs')}>プログラム</a>
      <span class="sep">/</span>
      <a href={localePath(locale, '/#programs')}>{categoryLabel}</a>
      <span class="sep">/</span>
      <span>{meta.nameJa}</span>
    </nav>

    <header class="prog-header">
      <div class="badges">
        <span class={`badge badge--${levelBadge}`}>{levelLabel}</span>
        <span class="badge badge--days">{meta.daysPerWeek} 日/週</span>
        {meta.durationWeeks && <span class="badge badge--days">{meta.durationWeeks} 週間</span>}
      </div>
      <h1>{meta.nameJa} <span class="accent">計算ツール</span></h1>
      <p class="lead">{meta.seoDescJa}</p>
      <div class="quickstats">
        <div class="qs"><span class="k">頻度</span><span class="v num">{meta.daysPerWeek}<small> /wk</small></span></div>
        {meta.durationWeeks && <div class="qs"><span class="k">期間</span><span class="v num">{meta.durationWeeks}<small> wk</small></span></div>}
        {meta.intensityRange && <div class="qs"><span class="k">強度域</span><span class="v num">{meta.intensityRange}</span></div>}
      </div>
    </header>

    <ProgramGenerator
      client:only="preact"
      slug={meta.slug}
      locale={locale}
      isSmolov={meta.slug === 'smolov-jr'}
      messages={messages}
    />

    <section class="prog-section">
      <h2 class="prog-section__title">{meta.nameJa}に向いている人</h2>
      <p class="prog-section__body">{meta.targetAudienceJa}</p>
    </section>

    <section class="prog-section prog-faq">
      <h2 class="prog-section__title">{meta.nameJa}のよくある質問</h2>
      <div class="faq-list">
        {meta.faq.map(item => (
          <details class="faq-item" name="faq-group">
            <summary class="faq-question">{item.questionJa}</summary>
            <div class="faq-answer"><p>{item.answerJa}</p></div>
          </details>
        ))}
      </div>
    </section>

    {relatedPrograms.length > 0 && (
      <section class="prog-section prog-related">
        <h2 class="prog-section__title">関連する筋力プログラム</h2>
        <div class="related-grid">
          {relatedPrograms.map(r => (
            <a href={localePath(locale, `/programs/${r.slug}`)} class="related-card">
              <span class="related-card__name">{r.nameJa}</span>
              <span class="related-card__desc">{r.descJa}</span>
              <span class="related-card__arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
.container { padding-bottom: 96px; }
</style>
